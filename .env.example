# ─────────────────────────────────────────────────────────────────────────────
# Telegram bot
# Create a bot with @BotFather, then paste the token it gives you here.
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# MAIN group (login/logout) — numeric id, e.g. -1001234567890. REQUIRED.
TELEGRAM_GROUP=

# BREAK groups — comma-separated numeric ids of the 2 break groups.
# Messages here are parsed as breaks ("Taking 30", "taking urgent 15", ...).
TELEGRAM_BREAK_GROUPS=

# ─────────────────────────────────────────────────────────────────────────────
# Behaviour
# ─────────────────────────────────────────────────────────────────────────────
# Ignore any message dated before this day (interpreted in TIMEZONE). YYYY-MM-DD.
RECORD_FROM_DATE=2026-06-01

# Timezone used to decide the "working-day" date and to display times.
# Any IANA name works, e.g. America/New_York, Europe/London, Africa/Lagos.
TIMEZONE=America/New_York

# Case-insensitive phrases that mark a LOGIN or a LOGOUT (comma-separated).
# A message counts if it CONTAINS any of these anywhere (single line, two lines
# or three lines all work).
LOGIN_KEYWORDS=logged in
LOGOUT_KEYWORDS=goodnight,good night

# ─────────────────────────────────────────────────────────────────────────────
# Breaks (parsed in the break groups)
# ─────────────────────────────────────────────────────────────────────────────
# Keyword that marks a break message; the duration is the number after it.
BREAK_KEYWORDS=taking
# Word that marks a break as "urgent".
BREAK_URGENT_KEYWORDS=urgent
# Phrases (comma-separated) that mean a user has returned from a break. When one
# of these is posted in a break group it closes the user's open break, and the
# actual time away is compared against the stated duration ("taking 30"); anyone
# who overstays is flagged. Each phrase is matched as a whole word.
BACK_KEYWORDS=i'm back,im back,i am back,back,im online,back online

# Total break minutes allowed per day. A day is flagged if the tally goes over this.
DAILY_BREAK_ALLOWANCE_MIN=60

# Grace minutes for returning late from a break. A break is only flagged as late
# once the actual time away exceeds its stated duration ("taking 30") PLUS this
# grace — so coming back within 10 minutes of the expected time is never flagged.
BREAK_GRACE_MIN=10

# Do "urgent" breaks count toward the allowance? true|false
URGENT_COUNTS_TOWARD_ALLOWANCE=true

# ─────────────────────────────────────────────────────────────────────────────
# Storage backend
#   postgres -> production (PostgreSQL; the long-term source of truth)
#   json     -> local testing without a database (writes ./data/*.json)
# ─────────────────────────────────────────────────────────────────────────────
STORAGE_DRIVER=postgres

# PostgreSQL connection (same instance as the CRM on the VPS).
# Copy these from the CRM's server/.env. Apply migrations/003_add_attendance_tables.sql first.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm
DB_USER=crm_user
DB_PASSWORD=
DB_SSL=false

# ─────────────────────────────────────────────────────────────────────────────
# Excel report (regenerated from the database for review; not the source of truth)
# ─────────────────────────────────────────────────────────────────────────────
DATA_DIR=./data
EXCEL_PATH=./data/attendance.xlsx
# Only used when STORAGE_DRIVER=json:
STORE_FILE=./data/attendance.json
STATE_FILE=./data/state.json

# Delay (ms) before the Excel file is rewritten after the last change.
EXCEL_DEBOUNCE_MS=4000

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info
